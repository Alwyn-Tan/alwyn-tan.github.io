---
import BaseHead from '../components/BaseHead.astro';
import Footer from '../components/Footer.astro';
import Header from '../components/Header.astro';
import { SITE_DESCRIPTION, SITE_TITLE } from '../consts';
---

<!doctype html>
<html lang="en">
	<head>
		<BaseHead title={`About | ${SITE_TITLE}`} description={SITE_DESCRIPTION} />
	</head>
	<body>
		<Header />
		<main>
			<h1>About</h1>
			<p>
				I'm Alwyn S X Tan. I write about software, AI systems, and how complex tools actually behave once you
				trace the implementation details.
			</p>
			<p>
				My recent interests sit around engineering walkthroughs, data pipelines, and practical AI workflows,
				especially when there is a gap between the high-level story and the code underneath.
			</p>
			<p>
				This site is where I collect notes, essays, and project write-ups. You can also find me on GitHub,
				LinkedIn, and X through the links in the header and footer.
			</p>
		</main>
		<Footer />
	</body>
</html>
