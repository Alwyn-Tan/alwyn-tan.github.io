---
import BaseHead from '../components/BaseHead.astro';
import Footer from '../components/Footer.astro';
import Header from '../components/Header.astro';
import { SITE_DESCRIPTION, SITE_TITLE } from '../consts';
---

<!doctype html>
<html lang="en">
	<head>
		<BaseHead title={SITE_TITLE} description={SITE_DESCRIPTION} />
	</head>
	<body>
		<Header />
		<main>
			<h1>Alwyn S X Tan</h1>
			<p>
				I write about software, AI systems, and the engineering details that sit underneath polished product
				stories.
			</p>
			<p>
				This site is a small home for notes, build logs, and longer write-ups on implementation, data
				pipelines, and practical AI workflows.
			</p>
			<p>
				Start with the <a href="/blog">blog</a>, or head to the <a href="/about">about page</a> for a short
				introduction.
			</p>
		</main>
		<Footer />
	</body>
</html>
